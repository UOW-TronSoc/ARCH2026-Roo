# Rule for the ESP32 (Silicon Labs CP210x)
SUBSYSTEM=="tty", ATTRS{idVendor}=="10c4", ATTRS{idProduct}=="ea60", GROUP="plugdev", MODE="0666", SYMLINK+="roo_esp32"

# Rule for the Generic USB Camera
SUBSYSTEM=="video4linux", ATTRS{idVendor}=="1e45", ATTRS{idProduct}=="8022", GROUP="plugdev", MODE="0666", SYMLINK+="roo_camera"
